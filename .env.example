# Database
POSTGRES_PASSWORD=contentflow
DATABASE_URL=postgresql://contentflow:contentflow@postgres:5432/contentflow

# Redis
REDIS_URL=redis://redis:6379/0

# AI - Google Gemini (gratis: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq fallback (gratis: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Reddit API (gratis: https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ContentFlow/1.0

# LinkedIn API (para publicación)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_id

# Email / Newsletter (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
NEWSLETTER_FROM=ContentFlow <your@gmail.com>
NEWSLETTER_TO=subscriber1@email.com,subscriber2@email.com

# RSS Feeds (separados por coma)
RSS_FEEDS=https://techcrunch.com/feed/,https://hnrss.org/frontpage,https://dev.to/feed

# Reddit subreddits a monitorear (separados por coma)
REDDIT_SUBREDDITS=artificial,MachineLearning,startups,technology

# Configuración de generación
CONTENT_CHANNELS=linkedin,blog,newsletter
MONITOR_INTERVAL_HOURS=6
MAX_TRENDS_PER_RUN=10
MIN_RELEVANCE_SCORE=6

# App
APP_ENV=development
SECRET_KEY=change_this_in_production
CORS_ORIGINS=http://localhost:3000
